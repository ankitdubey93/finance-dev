{
  "name": "rag-router-ai",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uvicorn app.main:app --host 0.0.0.0 --port ${RAG_ROUTER_AI_PORT:-8101} --reload",
        "cwd": "apps/rag-router-ai"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pip install -r requirements.txt",
        "cwd": "apps/rag-router-ai"
      }
    }
  }
}
