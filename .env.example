# ---------------------------------------------------------------------------
# Secrets & config — copy to `.env` and fill in. NEVER commit `.env`.
# The SPA never sees LLM keys; only the *-ai services consume them.
# ---------------------------------------------------------------------------

# --- Postgres (single instance, per-tool schemas) ---
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance
POSTGRES_DB=finance
POSTGRES_HOST=db
POSTGRES_PORT=5432

# App (read-write) connection — used by rag-router-ai (vector search + embedding
# writes) and by platform-api (the `platform` schema: companies/tenants).
DATABASE_URL=postgresql://finance:finance@db:5432/finance

# Read-only role — used ONLY by Text-to-SQL so generated SQL can never mutate.
# Role + grants are created in infra/db/init.
RAG_ROUTER_READONLY_URL=postgresql://rag_readonly:rag_readonly@db:5432/finance

# --- LLM providers (consumed only by rag-router-ai) ---
# Claude: routing decision + answer synthesis.
ANTHROPIC_API_KEY=sk-ant-...
RAG_ROUTER_ROUTE_MODEL=claude-haiku-4-5
RAG_ROUTER_SYNTH_MODEL=claude-opus-4-8

# Gemini: pgvector embeddings (Anthropic has no embeddings API).
GEMINI_API_KEY=...
RAG_ROUTER_EMBED_MODEL=gemini-embedding-001
RAG_ROUTER_EMBED_DIM=768

# --- Service wiring (internal URLs; SPA only ever calls the gateway) ---
PLATFORM_API_PORT=3000
RAG_ROUTER_API_PORT=3101
RAG_ROUTER_API_URL=http://rag-router-api:3101
RAG_ROUTER_AI_PORT=8101
RAG_ROUTER_AI_URL=http://rag-router-ai:8101
WEB_PORT=5173
